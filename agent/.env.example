# Copy this file to `agent/.env` and fill in your values.
# `.env` is gitignored — never commit your real key.
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env
# `CoreConfig.from_env()` loads `.env` automatically (without overriding real env vars).

OPENAI_API_KEY=sk-your-key-here

# Optional — a model your account can use (default: gpt-4o-mini)
# JOBPIN_MODEL_ID=gpt-4o-mini
# JOBPIN_DB_PATH=jobpin_sessions.db
# JOBPIN_MAX_TOOL_ITERS=8
